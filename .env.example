# =============================================================================
# MuleShield AI — Environment Configuration Template
# Copy this file to '.env' and fill in your local credentials.
# =============================================================================

# --- PostgreSQL Configuration ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=muleshield
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Neo4j Graph Database Configuration ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- AI & LLM Service Keys ---
# Primary AI client: Llama 3.3/3.1 instruct models via Groq API
GROQ_API_KEY=

# Secondary AI client: Llama 3.1 instruct models via NVIDIA NIM
NVIDIA_API_KEY=

# Tertiary AI client: OpenRouter LLM API
OPENROUTER_API_KEY=

# Fallback AI client: Gemini 2.0 Flash via Google GenAI SDK
GEMINI_API_KEY=

